# ─────────────────────────────────────────────
#  QA Portfolio — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/portfolio
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/portfolio
MONGODB_URI=mongodb://localhost:27017/portfolio

# Email service (gmail | outlook | yahoo | hotmail)
EMAIL_SERVICE=gmail

# Gmail address used to SEND emails
EMAIL_USER=yourname@gmail.com

# Gmail App Password (NOT your Gmail login password)
# Steps to generate:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Go to App passwords → Select "Mail" + "Other (Custom)"
#   4. Copy the 16-character password here
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Your email address where YOU receive contact notifications
# (can be same as EMAIL_USER or different)
OWNER_EMAIL=yourname@gmail.com

# Server port (default: 3000)
PORT=3000
